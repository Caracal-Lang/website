// paramethers are used to initialize the fields of the type
type Vector2D(x: i32, y: i32)
{
    // fields can be initialized with the parameters
    x := x;
    y := y;

    // methods are defined inside the type
    def lengthSquared() i32
    {
        return (.x * .x) + (.y * .y);
    }

    // static methods are defined with the type name
    def Vector2D.Zero() Vector2D
    {
        return Vector2D.new(0, 0);
    }
}
